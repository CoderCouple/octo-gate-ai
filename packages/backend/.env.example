# Postgres. In prod: Supabase transaction pooler on port 6543.
# Local dev: docker compose brings up Postgres on 55432 (non-standard so it
# doesn't collide with a native Postgres.app / Homebrew install on 5432).
DATABASE_URL=postgres://octogate:octogate@localhost:55432/octogate

# Redis. In prod: Upstash rediss://. Local dev: docker compose on 63790
# (again non-standard to avoid a local Redis on 6379).
REDIS_URL=redis://localhost:63790

# HMAC key for signing tokens. Required in prod.
# Generate with: openssl rand -hex 32
OCTOGATE_SECRET=dev-only-secret-do-not-use-in-prod-0123456789abcdef

# Requests per IP per minute. Default 30.
RATE_LIMIT=30

# Minimum acceptable solve time in ms. Answers arriving faster are rejected as too_fast.
MIN_SOLVE_MS=800

# Never set in production. DEBUG=1 puts the answer in the challenge response.
# DEBUG=

# Port the HTTP server listens on.
PORT=3000
